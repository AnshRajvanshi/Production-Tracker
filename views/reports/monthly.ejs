<div class="mb-4">
  <div class="d-flex justify-content-between align-items-center">
    <h2 class="fw-bold"><i class="bi bi-calendar-month"></i> Monthly Report</h2>
    <div>
      <a href="/reports/monthly/export?month=<%= reportMonth %>&year=<%= reportYear %>" class="btn btn-success btn-sm"><i class="bi bi-download"></i> Download Excel</a>
      <a href="/reports" class="btn btn-outline-secondary btn-sm"><i class="bi bi-arrow-left"></i> All Reports</a>
    </div>
  </div>
</div>

<!-- Month Selector -->
<div class="card border-0 shadow-sm mb-4">
  <div class="card-body">
    <form method="GET" action="/reports/monthly" class="row g-2 align-items-end">
      <div class="col-md-3">
        <label for="month" class="form-label">Month</label>
        <select class="form-select" id="month" name="month">
          <% for(let m = 1; m <= 12; m++) { %>
          <option value="<%= String(m).padStart(2, '0') %>" <%= reportMonth === String(m).padStart(2, '0') ? 'selected' : '' %>>
            <%= new Date(2026, m-1, 1).toLocaleString('en', { month: 'long' }) %>
          </option>
          <% } %>
        </select>
      </div>
      <div class="col-md-3">
        <label for="year" class="form-label">Year</label>
        <select class="form-select" id="year" name="year">
          <% for(let y = 2026; y <= 2030; y++) { %>
          <option value="<%= y %>" <%= String(reportYear) === String(y) ? 'selected' : '' %>><%= y %></option>
          <% } %>
        </select>
      </div>
      <div class="col-md-3">
        <button type="submit" class="btn btn-primary"><i class="bi bi-search"></i> View Report</button>
      </div>
    </form>
  </div>
</div>

<!-- Summary Cards -->
<div class="row g-3 mb-4">
  <div class="col-md-4">
    <div class="card border-0 shadow-sm bg-primary bg-opacity-10">
      <div class="card-body text-center">
        <h6 class="text-muted">Total Production</h6>
        <h3 class="fw-bold"><%= Number(totalMeters).toLocaleString() %> m</h3>
      </div>
    </div>
  </div>
  <div class="col-md-4">
    <div class="card border-0 shadow-sm bg-danger bg-opacity-10">
      <div class="card-body text-center">
        <h6 class="text-muted">Total Defects</h6>
        <h3 class="fw-bold"><%= Number(totalDefects).toLocaleString() %> m</h3>
      </div>
    </div>
  </div>
  <div class="col-md-4">
    <div class="card border-0 shadow-sm bg-warning bg-opacity-10">
      <div class="card-body text-center">
        <h6 class="text-muted">Defect %</h6>
        <h3 class="fw-bold"><%= defectPct %>%</h3>
      </div>
    </div>
  </div>
</div>

<!-- Daily Breakdown -->
<div class="card border-0 shadow-sm">
  <div class="card-body">
    <h5 class="fw-bold mb-3">
      Daily Breakdown - <%= new Date(2026, parseInt(reportMonth)-1, 1).toLocaleString('en', { month: 'long' }) %> <%= reportYear %>
    </h5>
    <div class="table-responsive">
      <table class="table table-hover">
        <thead class="table-light">
          <tr>
            <th>Date</th>
            <th class="text-end">Meters Produced</th>
            <th class="text-end">Defect Meters</th>
            <th class="text-end">Defect %</th>
          </tr>
        </thead>
        <tbody>
          <% dailySummary.forEach(function(day) { %>
          <tr>
            <td><%= day.date %></td>
            <td class="text-end"><%= Number(day.total_meters).toLocaleString() %></td>
            <td class="text-end"><%= Number(day.total_defects).toLocaleString() %></td>
            <td class="text-end">
              <% const pct = day.total_meters > 0 ? ((day.total_defects / day.total_meters) * 100).toFixed(1) : 0; %>
              <%= pct %>%
            </td>
          </tr>
          <% }); %>
          <% if (dailySummary.length === 0) { %>
          <tr><td colspan="4" class="text-center text-muted py-4">No data for this month.</td></tr>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>
</div>