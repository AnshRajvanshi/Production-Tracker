<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Production Tracker</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
  <link rel="stylesheet" href="/css/style.css">
  <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
</head>
<body>
  <% if (user) { %>
  <nav class="navbar navbar-expand-lg navbar-dark bg-primary">
    <div class="container-fluid">
      <a class="navbar-brand fw-bold" href="/">
        <i class="bi bi-gear-wide-connected"></i> Production Tracker
      </a>
      <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
        <span class="navbar-toggler-icon"></span>
      </button>
      <div class="collapse navbar-collapse" id="navbarNav">
        <ul class="navbar-nav me-auto">
          <li class="nav-item">
            <a class="nav-link" href="/dashboard"><i class="bi bi-speedometer2"></i> Dashboard</a>
          </li>
          <li class="nav-item">
            <a class="nav-link" href="/production"><i class="bi bi-clipboard-data"></i> Production</a>
          </li>
          <li class="nav-item">
            <a class="nav-link" href="/production/add"><i class="bi bi-plus-circle"></i> New Entry</a>
          </li>
          <% if (user.role === 'admin' || user.role === 'supervisor') { %>
          <li class="nav-item">
            <a class="nav-link" href="/machines"><i class="bi bi-display"></i> Machines</a>
          </li>
          <li class="nav-item dropdown">
            <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown">
              <i class="bi bi-file-earmark-bar-graph"></i> Reports
            </a>
            <ul class="dropdown-menu">
              <li><a class="dropdown-item" href="/reports/daily">Daily Report</a></li>
              <li><a class="dropdown-item" href="/reports/weekly">Weekly Report</a></li>
              <li><a class="dropdown-item" href="/reports/monthly">Monthly Report</a></li>
              <li><a class="dropdown-item" href="/reports/machine-wise">Machine-wise Report</a></li>
            </ul>
          </li>
          <% } %>
        </ul>
        <ul class="navbar-nav">
          <li class="nav-item dropdown">
            <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown">
              <i class="bi bi-person-circle"></i> <%= user.name %> (<%= user.role.replace('_', ' ') %>)
            </a>
            <ul class="dropdown-menu dropdown-menu-end">
              <li><a class="dropdown-item" href="/logout"><i class="bi bi-box-arrow-right"></i> Logout</a></li>
            </ul>
          </li>
        </ul>
      </div>
    </div>
  </nav>
  <% } %>

  <div class="container-fluid py-3">
    <%- body %>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>