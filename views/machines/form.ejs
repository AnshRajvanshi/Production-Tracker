<div class="row justify-content-center">
  <div class="col-md-6">
    <div class="card border-0 shadow-sm">
      <div class="card-body p-4">
        <h4 class="fw-bold mb-4">
          <% if (machine) { %>
          <i class="bi bi-pencil"></i> Edit Machine
          <% } else { %>
          <i class="bi bi-plus-lg"></i> Add Machine
          <% } %>
        </h4>

        <% if (error) { %>
        <div class="alert alert-danger"><%= error %></div>
        <% } %>

        <form action="<%= machine ? '/machines/edit/' + machine.id : '/machines/add' %>" method="POST">
          <div class="mb-3">
            <label for="machine_number" class="form-label">Machine Number</label>
            <input type="text" class="form-control" id="machine_number" name="machine_number" 
                   value="<%= machine ? machine.machine_number : '' %>" required
                   placeholder="e.g., M-001">
          </div>
          <div class="mb-3">
            <label for="machine_name" class="form-label">Machine Name</label>
            <input type="text" class="form-control" id="machine_name" name="machine_name" 
                   value="<%= machine ? machine.machine_name : '' %>" required
                   placeholder="e.g., Machine 1">
          </div>
          <div class="mb-3">
            <label for="status" class="form-label">Status</label>
            <select class="form-select" id="status" name="status">
              <option value="running" <%= machine && machine.status === 'running' ? 'selected' : '' %>>Running</option>
              <option value="idle" <%= machine && machine.status === 'idle' ? 'selected' : '' %>>Idle</option>
              <option value="maintenance" <%= machine && machine.status === 'maintenance' ? 'selected' : '' %>>Maintenance</option>
              <option value="breakdown" <%= machine && machine.status === 'breakdown' ? 'selected' : '' %>>Breakdown</option>
            </select>
          </div>
          <div class="d-flex justify-content-between">
            <a href="/machines" class="btn btn-outline-secondary"><i class="bi bi-arrow-left"></i> Back</a>
            <button type="submit" class="btn btn-primary">
              <i class="bi bi-check-lg"></i> <%= machine ? 'Update' : 'Save' %>
            </button>
          </div>
        </form>
      </div>
    </div>
  </div>
</div>